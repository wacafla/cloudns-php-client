{
    "name": "cloudns/api-client",
    "description": "A PHP 8.4 client for the ClouDNS HTTP API, covering DNS zones, records, domains, DNSSEC, mail forwards, and more.",
    "type": "library",
    "keywords": ["cloudns", "dns", "api", "client", "http"],
    "homepage": "https://github.com/cloudns/cloudns-php-client",
    "license": "MIT",
    "authors": [
        {
            "name": "ClouDNS",
            "homepage": "https://www.cloudns.net"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.9",
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "guzzlehttp/guzzle": "A popular PSR-18 HTTP client implementation",
        "symfony/http-client": "An alternative PSR-18 HTTP client implementation"
    },
    "autoload": {
        "psr-4": {
            "ClouDNS\\ApiClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ClouDNS\\ApiClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
